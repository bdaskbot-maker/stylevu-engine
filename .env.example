# StyleVu Environment Variables
# Copy this file to .env.local and fill in your values

# Brand ID - determines which brand config to load
# Available: demo, aarong-example (or add your own in src/brands/)
VITE_BRAND_ID=demo

# Proxy URL - endpoint for the AI try-on service
VITE_PROXY_URL=https://gemini-proxy.stylevu.com

# Image Base URL - CDN for product images (optional)
VITE_IMAGE_BASE_URL=https://images.stylevu.com
